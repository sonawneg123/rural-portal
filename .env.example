# ============================================================
# RURAL PORTAL BACKEND — Environment Variables
# Copy this file to .env and fill in real values
# ============================================================

# ── Server ────────────────────────────────────────────────────
NODE_ENV=production
PORT=5000
FRONTEND_URL=http://your-external-alb-dns.ap-south-1.elb.amazonaws.com

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET=replace_with_min_48_char_random_string_use_openssl_rand_base64_48
JWT_EXPIRES_IN=7d

# ── MySQL RDS ────────────────────────────────────────────────
DB_HOST=your-rds-endpoint.xxxxxx.ap-south-1.rds.amazonaws.com
DB_PORT=3306
DB_NAME=rural_portal
DB_USER=admin
DB_PASSWORD=YourStrongRDSPassword123!
DB_POOL_SIZE=10

# ── AWS S3 (photo uploads) ────────────────────────────────────
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
S3_BUCKET_NAME=rural-portal-photos
S3_BASE_URL=https://rural-portal-photos.s3.ap-south-1.amazonaws.com

# ── Groq AI API ───────────────────────────────────────────────
# Get your free key at: https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_MODEL=llama3-8b-8192

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=info
